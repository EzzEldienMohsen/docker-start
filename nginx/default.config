# This is the main HTTP server block.
# nginx listens on port 80 inside the container (docker-compose maps host:8080 → container:80).
# So any request you make to http://localhost:8080 hits this block.
server {

    listen 80;

    # The location block defines how nginx handles a specific URL path.
    # "/" means "match every request" — this is the catch-all proxy rule.
    location / {

        # proxy_pass is the core directive: it tells nginx to FORWARD
        # the incoming request to another server instead of serving a file.
        #
        # "node-app" is the Docker service name from docker-compose.yml.
        # Docker's internal DNS resolves "node-app" to that container's IP
        # automatically — you never need to hardcode an IP address.
        #
        # Port 5000 is the port your Node app listens on inside its container.
        proxy_pass http://node-app:5000;

        # Forward the original Host header (e.g. "localhost") to the Node app.
        # Without this, the app sees "node-app:5000" as the Host, which can
        # break host-based routing or logging.
        proxy_set_header Host $host;

        # Forward the real client IP address to the Node app.
        # $remote_addr is the IP of whoever connected to nginx.
        # Your app can read this from the "X-Real-IP" header.
        proxy_set_header X-Real-IP $remote_addr;

        # X-Forwarded-For is the standard way to pass the original client IP
        # through a chain of proxies. nginx appends the client IP to any
        # existing value (useful when there are multiple proxies in front).
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_redirect off;
    }
}

